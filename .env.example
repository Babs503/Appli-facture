# Configuration Supabase — copier ce fichier en .env.local et renseigner les valeurs.
# Disponibles dans le dashboard Supabase : Project Settings > API.
# .env.local est ignoré par git (ne jamais committer ces valeurs).

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique
